# FileStoreBot environment-variable example
#
# HOW TO USE LOCALLY:
#   cp .env.example .env
#   Edit every value marked CHANGE_ME. Do not commit .env.
#   Export it before starting the bot:
#     set -a; . ./.env; set +a; python main.py
#
# HOW TO USE ON RENDER:
#   Render Dashboard -> your Web Service -> Environment -> Add Environment Variable.
#   Add each variable below (without the leading # comments). Mark secrets as Secret.
#   Do NOT upload this file or expose BOT_TOKEN, API_HASH, or MONGODB_URI.
#
# You may use either these individual variables OR one SETUP_JSON secret as documented
# in README.md. SETUP_JSON takes priority when it is set.

# HTTP port. Render sets PORT automatically. Default for local use: 10000.
PORT=10000

# Optional log level: DEBUG, INFO, WARNING, ERROR. Default: INFO.
LOG_LEVEL=INFO

# A local PyroFork session name. Use letters/numbers/underscore, e.g. filestore_bot.
BOT_SESSION=filestore_bot

# Secret: BotFather -> /newbot -> copy the HTTP API token.
BOT_TOKEN=CHANGE_ME_BOTFATHER_TOKEN

# Telegram app credentials: create/retrieve them at https://my.telegram.org/apps.
# API_ID is numeric; API_HASH is secret.
API_ID=12345678
API_HASH=CHANGE_ME_TELEGRAM_API_HASH

# Your numeric Telegram user ID. Get it by messaging @userinfobot.
# The owner is always an administrator.
OWNER_ID=123456789

# Comma-separated numeric Telegram IDs allowed to administer/upload to the bot.
# Include OWNER_ID. Example: 123456789,987654321
ADMIN_IDS=123456789

# Secret: MongoDB connection URI. Atlas: Database -> Connect -> Drivers -> Python.
# URL-encode special characters in the database password.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name that the bot should use.
MONGODB_DB=filestorebot

# Numeric ID of the private Telegram channel used to store files (usually begins -100).
# Add the bot as a channel admin with permission to post and delete messages.
DB_CHANNEL_ID=-1001234567890

# Number of Telegram workers. Default: 8.
BOT_WORKERS=8

# Optional force-subscription channels as JSON.
# Use [] to disable. Each entry: [channel_id, join_request_boolean, expiry_minutes].
# The bot must be an admin with invite-link permission in every listed channel.
FSUBS_JSON=[]

# Seconds before delivered files are automatically deleted. Set 0 to disable. Default: 0.
AUTO_DELETE_SECONDS=0

# true prevents users from forwarding/saving delivered content where Telegram supports it.
# Default: false.
PROTECT_CONTENT=false

# true removes share buttons from copied database posts. Default: true.
DISABLE_BUTTONS=true

# Optional bot messages. Telegram HTML/Markdown and placeholders are supported.
# START supports: {first}, {last}, {username}, {mention}, {id}.
START_MESSAGE=Hello {mention}! Send me a file link to retrieve it.
FSUB_MESSAGE=Please join the required channel(s) to continue.
# ABOUT also supports: {owner_id}, {bot_username}.
ABOUT_MESSAGE=A private file-store bot.
REPLY_MESSAGE=You are not allowed to use this command.

# Optional public HTTPS URL or Telegram file ID for start/force-sub images. Empty disables it.
START_PHOTO=
FSUB_PHOTO=

# Optional delivered-file caption template. {previouscaption} inserts original caption.
CAPTION_TEMPLATE=

# Optional maximum batch length. The application default and safety cap is 200.
MAX_BATCH_SIZE=200
